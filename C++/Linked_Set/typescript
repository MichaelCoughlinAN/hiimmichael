    24	template <typename ItemType>
    25	LinkedSet<ItemType>::LinkedSet(const LinkedSet<ItemType>& aSet) {
    26	
    27	  itemCount = aSet.itemCount;
    28	
    29	  if (aSet.headPtr == nullptr) {
    30	    headPtr = nullptr;
    31	  }
    32	  else {
    33	    Node<ItemType>* origChainPtr = aSet.headPtr;
    34	
    35	    headPtr = new Node<ItemType>();
    36	    headPtr->setItem(origChainPtr->getItem() );
    37	
    38	    Node<ItemType>* newChainPtr = headPtr;
    39	
    40	    origChainPtr = origChainPtr->getNext();
    41	
    42	    while (origChainPtr != nullptr) {
    43	      ItemType nextItem = origChainPtr->getItem();
    44	
    45	      Node<ItemType>* newNodePtr = new Node<ItemType>(nextItem);
    46	
    47	      newChainPtr->setNext(newNodePtr);
    48	      newChainPtr = newChainPtr->getNext();
    49	      origChainPtr = origChainPtr->getNext();
    50	    }
    51	    newChainPtr->setNext(nullptr);
    52	  }
    53	}
