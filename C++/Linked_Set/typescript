    73	template <typename ItemType>
    74	bool LinkedSet<ItemType>::add(const ItemType& newEntry) {
    75	  Node<ItemType>* newNodePtr = new Node<ItemType>();
    76	  if(!contains(newEntry)){ 
    77	  newNodePtr->setItem(newEntry);
    78	  newNodePtr->setNext(headPtr);
    79	  headPtr = newNodePtr;
    80	  ++itemCount;
    81	 
    82	 return true;
    83	  }else return false;
    84	}
