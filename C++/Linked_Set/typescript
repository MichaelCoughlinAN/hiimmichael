    86	template <typename ItemType>
    87	bool LinkedSet<ItemType>::remove(const ItemType& anEntry) {
    88	  bool canRemoveItem = !isEmpty();
    89	
    90	  if (canRemoveItem) {
    91	    Node<ItemType>* entryNodePtr = getPointerTo(anEntry);
    92	    canRemoveItem = entryNodePtr != nullptr;
    93	
    94	    if (canRemoveItem) {
    95	      entryNodePtr->setItem(headPtr->getItem() );
    96	
    97	      Node<ItemType>* nodeToDeletePtr = headPtr;
    98	
    99	      headPtr = headPtr->getNext();
   100	      nodeToDeletePtr->setNext(nullptr);
   101	      delete nodeToDeletePtr;
   102	      nodeToDeletePtr = nullptr;
   103	      --itemCount;
   104	    }
   105	  }
   106	  return canRemoveItem;
   107	}
