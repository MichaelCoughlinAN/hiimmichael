    53	  events.remove(); // Delete currentEvent from event list
    54	
    55	 
    56	
    57	    if (!line.isEmpty() ) {
    58	     Event newEvent = line.peekFront();
    59	     events.add(eventBuilder.createDepartureEvent(currentEvent.getTime(), 
    60	                                                  newEvent.getDuration(),
    61	                                                  newEvent.getNumber() ));
