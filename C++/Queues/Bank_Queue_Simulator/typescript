    32	void Simulation::processArrival() {
    33	  bool lineIsEmpty = line.isEmpty(); 
    34	  line.enqueue(currentEvent); //Put currentEvent at the end of the queue
    35	  events.remove(); //Delete currentEvent from event list
    36	 
    37	     if (lineIsEmpty) {
    38	       events.add(eventBuilder.createDepartureEvent(currentEvent.getTime(), 
    39	                                                    currentEvent.getDuration(), 
    40	                                                    currentEvent.getNumber() )); 
    41	       // Insert into event list a departure event corresponding
    42	       // to current event (customer) with currTime = currTime + transLength
    43	     }
    44	     Event newEvent = eventBuilder.createArrivalEvent(currentEvent.getNumber() + 1); // Create a new arrival event newEvent
    45					 
    46	  if (newEvent.getNumber() != 0) {
    47	      events.add(newEvent);
    48		}  
    49	}
