    95	    returnPtr = subTreePtr;
    96	  }
    97	  else if (rightPtr != nullptr) {
    98	    subTreePtr->item = rightPtr->item;
    99	    rightPtr = moveValuesUpTree(rightPtr);
   100	    subTreePtr->rightChildPtr = rightPtr;
   101	    returnPtr = subTreePtr;
   102	  }
   103	  else {
   104	    // This is a leaf - Remove it from this tree.
   105	    delete subTreePtr;
   106	  }
   107	
   108	  return returnPtr;
