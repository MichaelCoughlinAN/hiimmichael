    55	template <typename ItemType>
    56	BinaryNode<ItemType>* BinaryNodeTree<ItemType>::balancedAdd(BinaryNode<ItemType>* subTreePtr,
    57	                                                            BinaryNode<ItemType>* newNodePtr) {
    58	
    59	  BinaryNode<ItemType>* returnPtr = newNodePtr;
    60	
    61	  if (subTreePtr != nullptr) {
    62	    BinaryNode<ItemType>* leftPtr = subTreePtr->leftChildPtr;
    63	    BinaryNode<ItemType>* rightPtr = subTreePtr->rightChildPtr;
    64	
    65	    if (getHeightHelper(leftPtr) > getHeightHelper(rightPtr) ) {
    66	      rightPtr = balancedAdd(rightPtr, newNodePtr);
    67	      subTreePtr->rightChildPtr = rightPtr;
    68	    }
    69	    else {
    70	      leftPtr = balancedAdd(leftPtr, newNodePtr);
    71	      subTreePtr->leftChildPtr = leftPtr;
