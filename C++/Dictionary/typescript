   113	 *  @param subTreePtr The tree to search.
   114	 *
   115	 *  @param target The target item to find.
   116	 *
   117	 *  @param success Communicate to client whether we found the target.
   118	 *
   119	 *  @return A pointer to the node containing the target. */
   120	template <typename ItemType>
   121	BinaryNode<ItemType>* BinaryNodeTree<ItemType>::removeValue(BinaryNode<ItemType>* subTreePtr,
   122	                                                            const ItemType target,
   123	                                                            bool& success) {
   124	
   125	  // Assume target cannot be found.
   126	  BinaryNode<ItemType>* returnPtr = nullptr;
   127	  success = false;
   128	
   129	  if(subTreePtr != nullptr) {
   130	    if (subTreePtr->item == target) {
   131	      subTreePtr = moveValuesUpTree(subTreePtr);
   132	      success = true;
   133	      returnPtr = subTreePtr;
   134	    }
   135	    else {
   136	      BinaryNode<ItemType>* targetNodePtr = removeValue(subTreePtr->leftChildPtr,
   137								target,
   138								success);
   139	      subTreePtr->leftChildPtr = targetNodePtr;
   140	
   141	      if (!success) {
   142		targetNodePtr = removeValue(subTreePtr->rightChildPtr,
   143					    target,
   144					    success);
   145		subTreePtr->rightChildPtr = targetNodePtr;
   146	      }
   147	
   148	      returnPtr = subTreePtr;
   149	    }
   150	  }
   151	
   152	  return returnPtr;
   153	}
